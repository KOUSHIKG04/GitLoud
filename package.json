{
  "name": "GitLoud",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "web": "turbo run dev --filter=web",
    "mobile": "turbo run dev --filter=mobile",
    "android": "npm --workspace mobile run android",
    "ios": "npm --workspace mobile run ios",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "zod": "4.3.6"
  }
}
